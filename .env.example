# ─── Azure SQL Database ───────────────────────────────────────────────
DB_SERVER=your-server.database.windows.net
DB_NAME=your-database-name
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_PORT=1433

# ─── Session Secret ───────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars

# ─── App ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
